# Copy to .env on your homelab before: docker compose up -d

# Required — admin panel auth
JWT_SECRET=generate-a-long-random-string-here

# Public URL users and webhooks should link to (no trailing slash)
BASE_URL=https://realm.example.com

# Host port published on the Ubuntu server (container stays on 3000 internally)
HOST_PORT=3000

# Optional image tag (default: latest from GitHub Container Registry)
# REALM_IMAGE_TAG=latest

# Optional — all mutable data under one host directory
# REALM_DATA_DIR=./realm-data

# Optional webhook env fallbacks (admin panel settings are preferred)
DISCORD_WEBHOOK_URL=
HAVEN_WEBHOOK_URL=
